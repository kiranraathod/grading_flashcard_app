          bottom: BorderSide(
            color: const Color(0xFF10B981).withOpacity(0.2),
          ),
        ),
      ),
      child: Row(
        children: [
          // Timer icon with background
          Container(
            width: 32,
            height: 32,
            decoration: const BoxDecoration(
              color: Color(0xFF10B981),
              shape: BoxShape.circle,
