// ✨ ENHANCED VISUAL IMPROVEMENTS ✨
// These are the visual enhancements to make your UI more professional

class InterviewPracticeScreen extends StatefulWidget {
  final InterviewQuestion question;
  final List<InterviewQuestion> questionList;
  final int currentIndex;

  const InterviewPracticeScreen({
    super.key,
    required this.question,
    required this.questionList,
    required this.currentIndex,
  });

  @override
  State<InterviewPracticeScreen> createState() =>
      _InterviewPracticeScreenState();
}

class _InterviewPracticeScreenState extends State<InterviewPracticeScreen> {
  // [Keep all your existing state variables - no changes needed]
  bool _showAnswer = false;
  bool _isCompleted = false;
  int _timeTaken = 0;
  late InterviewService _interviewService;
  Timer? _timer;
  final TextEditingController _userAnswerController = TextEditingController();
  bool _isGrading = false;
  bool _isSubmittingBatch = false;
  bool _hasLoadedInitialAnswer = false;
  final Map<String, String> _userAnswers = {};
  InterviewAnswer? _gradedAnswer;
  final InterviewApiService _interviewApiService = InterviewApiService();
  
  // ✅ NEW: Focus node for enhanced text input
  final FocusNode _answerFocusNode = FocusNode();
  bool _isTextFieldFocused = false;

  @override
  void initState() {
    super.initState();
    _isCompleted = widget.question.isCompleted;
    _userAnswerController.addListener(_autoSaveAnswer);
    _startTimer();
    
    // ✅ NEW: Listen to focus changes for visual enhancements
    _answerFocusNode.addListener(() {
      setState(() {
        _isTextFieldFocused = _answerFocusNode.hasFocus;
      });
    });
  }

  // [Keep all your existing methods - just the build method changes]
  // ... (all your existing methods like _loadCurrentAnswer, _saveCurrentAnswer, etc.)
  
  // Keep all existing methods exactly as they are, just replacing the build method:

  @override
  Widget build(BuildContext context) {
    return Builder(
      builder: (context) {
        WidgetsBinding.instance.addPostFrameCallback((_) {
          context.read<RecentViewBloc>().add(
            RecordInterviewQuestionView(
              question: widget.question,
              category: widget.question.category,
            ),
          );
        });

        return Scaffold(
          // ✨ ENHANCED APP BAR
          appBar: _buildEnhancedAppBar(context),
          
          body: Stack(
            children: [
              Column(
                children: [
                  // ✨ ENHANCED TIMER BAR
                  _buildEnhancedTimerBar(context),

                  // Main content area
                  Expanded(
                    child: SingleChildScrollView(
                      padding: const EdgeInsets.all(DS.spacingL),
                      child: Column(
                        crossAxisAlignment: CrossAxisAlignment.start,
                        children: [
                          // ✨ ENHANCED QUESTION CARD
                          _buildEnhancedQuestionCard(context),

                          const SizedBox(height: DS.spacingL),

                          // ✨ ENHANCED ANSWER INPUT
                          if (!_showAnswer) ...[
                            _buildEnhancedAnswerInput(context),
                          ] else ...[
                            // Keep your existing answer display logic
                            _buildAnswerDisplay(context),
                          ],
                        ],
                      ),
                    ),
                  ),

                  // ✨ ENHANCED BOTTOM ACTIONS
                  _buildEnhancedBottomActions(context),
                ],
              ),

              // Loading overlay (keep existing)
              if (_isGrading || _isSubmittingBatch)
                Container(
                  color: context.surfaceColor.withOpacityFix(0.5),
                  child: Center(
                    child: Column(
                      mainAxisSize: MainAxisSize.min,
                      children: [
                        CircularProgressIndicator(
                          valueColor: AlwaysStoppedAnimation<Color>(
                            context.primaryColor,
                          ),
                        ),
                        const SizedBox(height: DS.spacingM),
                        Text(
                          _isSubmittingBatch
                              ? 'Grading all answers...'
                              : 'Grading your answer...',
                          style: context.bodyLarge?.copyWith(
                            color: context.onSurfaceColor,
                          ),
                        ),
                      ],
                    ),
                  ),
                ),
            ],
          ),
        );
      },
    );
  }

