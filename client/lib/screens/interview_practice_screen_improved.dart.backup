  // ✨ ENHANCED BOTTOM ACTIONS
  Widget _buildEnhancedBottomActions(BuildContext context) {
    return Container(
      padding: const EdgeInsets.all(24),
      decoration: BoxDecoration(
        color: Colors.white,
        border: const Border(
          top: BorderSide(color: Color(0xFFE2E8F0)),
        ),
        boxShadow: [
          BoxShadow(
            color: Colors.black.withOpacity(0.05),
            blurRadius: 10,
            offset: const Offset(0, -2),
          ),
        ],
      ),
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          // Main action buttons
          Row(
            children: [
              // Previous button
              if (widget.currentIndex > 0) ...[
                Expanded(
                  flex: 2,
                  child: _buildEnhancedButton(
                    text: 'Previous',
                    icon: Icons.arrow_back,
                    onPressed: _moveToPreviousQuestion,
                    type: _ButtonType.outline,
                  ),
                ),
                const SizedBox(width: 16),
              ],
              
              // Next/Submit button (primary)
              Expanded(
                flex: 3,
                child: _buildEnhancedButton(
                  text: widget.currentIndex < widget.questionList.length - 1
                      ? 'Next Question'
                      : 'Submit Answer',
                  icon: widget.currentIndex < widget.questionList.length - 1
                      ? Icons.arrow_forward
                      : Icons.check,
                  onPressed: widget.currentIndex < widget.questionList.length - 1
                      ? _moveToNextQuestion
                      : _submitSingleAnswer,
                  type: _ButtonType.primary,
                ),
              ),
              
              // Grade All button
              if (widget.questionList.length > 1) ...[
                const SizedBox(width: 16),
                Expanded(
                  flex: 2,
                  child: _buildEnhancedButton(
                    text: 'Grade All\n(${_getAnsweredQuestionCount()}/${widget.questionList.length})',
                    icon: _getAnsweredQuestionCount() > 0 
                        ? Icons.grading 
                        : Icons.grading_outlined,
                    onPressed: () {
                      final answeredCount = _getAnsweredQuestionCount();
                      if (answeredCount > 0) {
                        _submitAllAnswers();
                      } else {
                        ScaffoldMessenger.of(context).showSnackBar(
                          const SnackBar(
                            content: Text('Please answer at least one question before submitting'),
                            duration: Duration(seconds: 2),
                          ),
                        );
                      }
                    },
                    type: _getAnsweredQuestionCount() > 0 
                        ? _ButtonType.success 
                        : _ButtonType.outline,
                  ),
                ),
              ],
            ],
          ),
        ],
      ),
    );
  }

  // ✨ ENHANCED BUTTON BUILDER
  Widget _buildEnhancedButton({
    required String text,
    IconData? icon,
    required VoidCallback? onPressed,
    required _ButtonType type,
  }) {
    Color backgroundColor;
    Color textColor;
    Border? border;
    List<BoxShadow>? boxShadow;
    Gradient? gradient;

    switch (type) {
      case _ButtonType.primary:
        gradient = const LinearGradient(
          colors: [Color(0xFF0D9488), Color(0xFF5EEAD4)],
          begin: Alignment.topLeft,
          end: Alignment.bottomRight,
        );
        textColor = Colors.white;
        boxShadow = [
          BoxShadow(
            color: const Color(0xFF0D9488).withOpacity(0.25),
            blurRadius: 8,
            offset: const Offset(0, 4),
          ),
        ];
        break;
      case _ButtonType.success:
        gradient = const LinearGradient(
          colors: [Color(0xFF10B981), Color(0xFF34D399)],
          begin: Alignment.topLeft,
          end: Alignment.bottomRight,
        );
        textColor = Colors.white;
        boxShadow = [
          BoxShadow(
            color: const Color(0xFF10B981).withOpacity(0.25),
            blurRadius: 8,
            offset: const Offset(0, 4),
          ),
        ];
        break;
      case _ButtonType.outline:
        backgroundColor = Colors.white;
        textColor = const Color(0xFF64748B);
        border = Border.all(color: const Color(0xFFE2E8F0), width: 2);
        break;
      case _ButtonType.secondary:
        backgroundColor = const Color(0xFFF8FAFC);
        textColor = const Color(0xFF475569);
        border = Border.all(color: const Color(0xFFE2E8F0));
        break;
    }

    return Material(
      color: Colors.transparent,
      child: InkWell(
        onTap: onPressed,
        borderRadius: BorderRadius.circular(10),
        child: AnimatedContainer(
          duration: const Duration(milliseconds: 150),
          padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 14),
          decoration: BoxDecoration(
            gradient: gradient,
            color: gradient == null ? backgroundColor : null,
            border: border,
            borderRadius: BorderRadius.circular(10),
            boxShadow: boxShadow,
          ),
          child: Row(
            mainAxisAlignment: MainAxisAlignment.center,
            mainAxisSize: MainAxisSize.min,
            children: [
              if (icon != null) ...[
                Icon(
                  icon,
                  size: 16,
                  color: textColor,
                ),
                const SizedBox(width: 8),
              ],
              Flexible(
                child: Text(
                  text,
                  textAlign: TextAlign.center,
                  style: TextStyle(
                    fontSize: type == _ButtonType.success && text.contains('\n') ? 12 : 15,
                    fontWeight: FontWeight.w600,
                    color: textColor,
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }

  // ✨ HELPER METHODS FOR VISUAL ENHANCEMENTS
  Color _getAnswerQualityColor() {
    final wordCount = _getWordCount(_userAnswerController.text);
    if (wordCount >= 80) return const Color(0xFF10B981); // Green - Excellent
    if (wordCount >= 50) return const Color(0xFF0D9488); // Teal - Good
    if (wordCount >= 25) return const Color(0xFFF59E0B); // Amber - Fair
    return const Color(0xFFEF4444); // Red - Poor
  }

  IconData _getAnswerQualityIcon() {
    final wordCount = _getWordCount(_userAnswerController.text);
    if (wordCount >= 80) return Icons.star;
    if (wordCount >= 50) return Icons.thumb_up;
    if (wordCount >= 25) return Icons.warning_amber;
    return Icons.error_outline;
  }

  String _getAnswerQualityText() {
    final wordCount = _getWordCount(_userAnswerController.text);
    if (wordCount >= 80) return 'Excellent';
    if (wordCount >= 50) return 'Good';
    if (wordCount >= 25) return 'Fair';
    return 'Too brief';
  }

  int _getWordCount(String text) {
    return text.trim().isEmpty ? 0 : text.trim().split(RegExp(r'\s+')).length;
  }

