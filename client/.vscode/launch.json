{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FlashMaster Debug (Port 3000)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "args": [
                "--web-port=3000"
            ],
            "deviceId": "chrome",
            "env": {
                "FLUTTER_WEB_PORT": "3000"
            }
        },
        {
            "name": "FlashMaster Release (Port 3000)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "args": [
                "--web-port=3000",
                "--release"
            ],
            "deviceId": "chrome",
            "env": {
                "FLUTTER_WEB_PORT": "3000"
            }
        }
    ]
}