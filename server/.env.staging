# =================================================================
# FlashMaster Staging Environment Configuration
# =================================================================
# 
# This template is for staging/preview deployments for testing
# production-like settings before final deployment
#
# USE CASE: Branch deployments, testing, staging environment
# =================================================================

# =================================================================
# 🚨 CRITICAL - REQUIRED FOR DEPLOYMENT
# =================================================================

# Google API Key for Gemini LLM integration
# 🔧 STAGING: Can use same API key as production (usage limits permitting)
GOOGLE_API_KEY=<YOUR_GOOGLE_API_KEY_HERE>

# LLM Model Configuration
LLM_MODEL=gemini-2.0-flash

# CORS Origins - Staging domains
# 🔧 STAGING: Include staging/preview domains
CORS_ORIGINS=https://staging-your-app.vercel.app,https://your-app-git-staging.vercel.app,https://saxopupmwfcfjxuflfrx.supabase.co

# =================================================================
# 📋 SERVER CONFIGURATION - STAGING
# =================================================================

# Server Configuration
PORT=10000

# Environment Type
ENV=staging

# Debug Mode
# 📝 STAGING: Can be true for debugging, false for production-like testing
DEBUG=False

# Logging Level
# 📝 STAGING: DEBUG for detailed logs, INFO for production-like testing
LOG_LEVEL=DEBUG

# =================================================================
# 🤖 AI/LLM CONFIGURATION
# =================================================================

# LLM Operation Timeout
LLM_TIMEOUT=60

# LLM Response Limits
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.2

# =================================================================
# 🗄️ DATABASE CONFIGURATION - OPTIONAL
# =================================================================

# Staging can use same Supabase project or separate staging project
# DB_URL=<STAGING_SUPABASE_DATABASE_URL>

# =================================================================
# ✅ STAGING DEPLOYMENT CHECKLIST
# =================================================================
#
# Before deploying to staging:
# [ ] GOOGLE_API_KEY is set (can reuse production key)
# [ ] CORS_ORIGINS contains staging/preview domains
# [ ] LOG_LEVEL set to DEBUG for detailed testing logs
# [ ] All placeholders replaced with staging values
#
# =================================================================