# =================================================================
# FlashMaster Production Environment Configuration
# =================================================================
# 
# This template contains all environment variables required for 
# production deployment on Render.com
#
# DEPLOYMENT INSTRUCTIONS:
# 1. Copy these variables to Render Environment Variables dashboard
# 2. Replace <placeholder> values with actual production values
# 3. Verify all REQUIRED variables are set before deployment
#
# =================================================================

# =================================================================
# 🚨 CRITICAL - REQUIRED FOR DEPLOYMENT
# =================================================================

# Google API Key for Gemini LLM integration
# 🚨 REQUIRED: Get from Google AI Studio (https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=<YOUR_GOOGLE_API_KEY_HERE>

# LLM Model Configuration
# ✅ RECOMMENDED: gemini-2.0-flash (fast, cost-effective)
LLM_MODEL=gemini-2.0-flash

# CORS Origins - Production domains only
# 🔧 REPLACE: Add your actual Vercel production domain
CORS_ORIGINS=https://your-vercel-app.vercel.app,https://saxopupmwfcfjxuflfrx.supabase.co

# =================================================================
# 📋 SERVER CONFIGURATION - RENDER DEFAULTS
# =================================================================

# Server Configuration
# ✅ RENDER MANAGED: Port is automatically assigned by Render
PORT=10000

# Environment Type
ENV=production

# Debug Mode
# 🚨 SECURITY: Always false in production
DEBUG=False

# Logging Level
# ✅ RECOMMENDED: INFO for production monitoring
LOG_LEVEL=INFO

# =================================================================
# 🤖 AI/LLM CONFIGURATION - PERFORMANCE TUNED
# =================================================================

# LLM Operation Timeout
# ✅ RENDER OPTIMIZED: 60 seconds (Render supports long operations vs Vercel 10s limit)
LLM_TIMEOUT=60

# LLM Response Limits
# ✅ PERFORMANCE TUNED: Optimal for flashcard responses
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.2

# =================================================================
# 🗄️ DATABASE CONFIGURATION - SUPABASE INTEGRATION
# =================================================================

# Supabase Configuration - Task 2.2 Implementation
# ✅ REQUIRED: Database connectivity for Task 2.2 and beyond
SUPABASE_URL=https://saxopupmwfcfjxuflfrx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNheG9wdXBtd2ZjZmp4dWZsZnJ4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3MTc4NDcyNTMsImV4cCI6MjAzMzQyMzI1M30.VqNLJ6OVTl-x3YkYL6bNs4k_c3r8VVoHhBgWJY8LQUo

# Database Performance Configuration
DB_POOL_SIZE=20
DB_TIMEOUT=30
DB_RETRY_ATTEMPTS=3

# =================================================================
# 📊 MONITORING & OBSERVABILITY - OPTIONAL
# =================================================================

# Application monitoring (add if using external monitoring services)
# SENTRY_DSN=<SENTRY_PROJECT_DSN>
# NEW_RELIC_LICENSE_KEY=<NEW_RELIC_KEY>

# =================================================================
# ✅ DEPLOYMENT CHECKLIST
# =================================================================
#
# Before deploying to Render, verify:
# [ ] GOOGLE_API_KEY is set to actual API key (not placeholder)
# [ ] CORS_ORIGINS contains your actual Vercel production domain
# [ ] PORT is set to 10000 (Render default) or assigned by Render
# [ ] DEBUG is False
# [ ] LLM_MODEL is set to a valid Google AI model
# [ ] All placeholders (<...>) have been replaced with real values
#
# =================================================================